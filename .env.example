# Bureau's pipeline scripts need a Linear API key to move tickets between
# states, post comments, and read labels. Get one at:
#   https://linear.app/settings/account/api  (name it "bureau-pipeline")
#
# The key is per-operator, not per-repo. Copy this file to `.env`, paste
# your key, and gitignore protects it from accidental commit.
#
# Optional Telegram alerting — leave blank to disable alerts silently.
#   TELEGRAM_BOT_TOKEN=
#   TELEGRAM_ALERT_CHAT_ID=

LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
